i<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Guia Rural Animal PRO</title>

<link rel="manifest" href="manifest.json">

<style>
:root {
  --bg:#0f172a;
  --card:#111827;
  --text:#e5e7eb;
  --accent:#22c55e;
}

.light {
  --bg:#f9fafb;
  --card:#fff;
  --text:#111827;
}

body { margin:0; font-family:Arial; background:var(--bg); color:var(--text);}
.container { max-width:1100px; margin:auto; padding:20px;}
.card { background:var(--card); padding:20px; border-radius:12px; margin-bottom:20px;}

button {
  padding:10px;
  border:none;
  border-radius:8px;
  background:var(--accent);
  color:white;
  cursor:pointer;
}

.tabs button { margin:3px;}

.tab { display:none;}
.tab.active { display:block;}

input,select {
  padding:8px;
  margin:5px 0;
  width:100%;
  border-radius:6px;
  border:none;
}

canvas {
  background:white;
  border-radius:10px;
  width:100%;
}

img {
  max-width:100%;
  border-radius:10px;
  margin-top:10px;
}

ul { padding-left:20px;}
</style>
</head>

<body>

<div class="container">

<!-- CONTROLES -->
<div class="card">
<button onclick="toggleTheme()">🌗 Tema</button>
<button onclick="toggleLang()">🌍 Idioma</button>

<div class="tabs">
<button onclick="tab(0)">🐣 Tabela</button>
<button onclick="tab(1)">📅 Calculadora</button>
<button onclick="tab(2)">🔥 Cuidados</button>
<button onclick="tab(3)">🏆 Ranking</button>
<button onclick="tab(4)">📊 Gráfico</button>
<button onclick="tab(5)">📸 Fotos</button>
<button onclick="tab(6)">💬 Comunidade</button>
</div>
</div>

<!-- TABELA -->
<div class="card tab active">
<table id="table"></table>
</div>

<!-- CALCULADORA -->
<div class="card tab">
<h3 id="calcTitle">Calculadora de nascimento</h3>
<select id="animal"></select>
<input type="date" id="date">
<button onclick="calc()">Calcular</button>
<p id="result"></p>
<button onclick="notify()">🔔 Ativar alerta</button>
<button onclick="share()">📲 WhatsApp</button>
</div>

<!-- CUIDADOS -->
<div class="card tab">
<h3>🔥 Temperatura</h3>
<ul>
<li>32–35°C primeira semana</li>
<li>Reduzir semanalmente</li>
<li>Aglutinados = frio</li>
<li>Espalhados = ideal</li>
</ul>

<h3>💡 Método Isopor</h3>
<ul>
<li>Caixa de isopor</li>
<li>Lâmpada 60W</li>
<li>Termômetro dentro</li>
<li>Ajustar altura</li>
</ul>

<h3>🥣 Alimentação</h3>
<ul>
<li>Ração inicial</li>
<li>Água limpa</li>
<li>Mais proteína para codorna</li>
</ul>
</div>

<!-- RANKING -->
<div class="card tab">
<h3>🏆 Ranking</h3>
<ol id="ranking"></ol>
</div>

<!-- GRÁFICO -->
<div class="card tab">
<h3>📊 Gestação</h3>
<canvas id="chart"></canvas>
</div>

<!-- FOTO -->
<div class="card tab">
<h3>📸 Compartilhe</h3>
<input type="file" onchange="preview(event)">
<img id="img">
</div>

<!-- COMUNIDADE -->
<div class="card tab">
<h3>💬 Comunidade</h3>
<input id="comment" placeholder="Digite sua experiência">
<button onclick="addComment()">Enviar</button>
<ul id="comments"></ul>
</div>

</div>

<script>
let pt=true;

const data=[
["Gato","Cat",60],
["Cachorro","Dog",60],
["Vaca","Cow",285],
["Ovelha","Sheep",150],
["Égua","Mare",340],
["Jumenta","Donkey",370],
["Galinha","Chicken",21],
["Codorna","Quail",17],
["Pavão","Peacock",29],
["Angola","Guinea fowl",27],
["Porco","Pig",114],
["Cabra","Goat",150]
];

let predictedDate=null;

function render(){
let t="<tr><th>Animal</th><th>Dias</th></tr>";
data.forEach(a=>{
t+=`<tr><td>${pt?a[0]:a[1]}</td><td>${a[2]}</td></tr>`;
});
table.innerHTML=t;

// select
animal.innerHTML=data.map((a,i)=>`<option value="${i}">${pt?a[0]:a[1]}</option>`).join("");

// ranking
let sorted=[...data].sort((a,b)=>b[2]-a[2]);
ranking.innerHTML=sorted.map(a=>`<li>${pt?a[0]:a[1]} - ${a[2]} dias</li>`).join("");

drawChart();
loadComments();
}

function calc(){
let i=animal.value;
let d=new Date(date.value);
d.setDate(d.getDate()+data[i][2]);
predictedDate=d;
result.innerText=d.toLocaleDateString();
}

function notify(){
if(!predictedDate) return alert("Calcule primeiro");

Notification.requestPermission().then(p=>{
if(p==="granted"){
new Notification("Alerta ativado!");
}
});
}

function share(){
window.open("https://wa.me/?text=Data prevista: "+result.innerText);
}

// gráfico
function drawChart(){
let c=document.getElementById("chart");
let ctx=c.getContext("2d");
c.height=250;

ctx.clearRect(0,0,c.width,c.height);

data.forEach((a,i)=>{
let h=a[2];
ctx.fillStyle="#22c55e";
ctx.fillRect(i*40,250-h/2,25,h/2);
ctx.fillStyle="black";
ctx.fillText(a[0],i*40,240);
});
}

// fotos
function preview(e){
img.src=URL.createObjectURL(e.target.files[0]);
}

// comentários
function addComment(){
let txt=comment.value;
if(!txt) return;
let list=JSON.parse(localStorage.getItem("comments")||"[]");
list.push(txt);
localStorage.setItem("comments",JSON.stringify(list));
comment.value="";
loadComments();
}

function loadComments(){
let list=JSON.parse(localStorage.getItem("comments")||"[]");
comments.innerHTML=list.map(c=>`<li>${c}</li>`).join("");
}

// UI
function toggleTheme(){document.body.classList.toggle("light");}
function toggleLang(){pt=!pt;render();}
function tab(n){
document.querySelectorAll(".tab").forEach((t,i)=>t.classList.toggle("active",i===n));
}

// PWA
if("serviceWorker" in navigator){
navigator.serviceWorker.register("service-worker.js");
}

render();
</script>

</body>
</html>
